# ===========================================
# Intelligent Joplin Librarian - DeepSeek Configuration
# ===========================================

# LLM Provider Selection
# DeepSeek is recommended for cost-effective, high-quality responses
LLM_PROVIDER=deepseek

# DeepSeek Configuration
# Get your FREE API key from: https://platform.deepseek.com/
# Sign up, go to API Keys, and create a new key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
# Send /newbot and follow the instructions
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Security Configuration
# Add your Telegram user ID (you can get it from @userinfobot)
ALLOWED_TELEGRAM_USER_IDS=your_user_id_here

# Joplin Configuration
# IMPORTANT: Set up Joplin Web Clipper authorization token
# 1. Open Joplin application
# 2. Go to Tools → Options → Web Clipper
# 3. Generate or set an authorization token
# 4. Copy the token here
JOPLIN_WEB_CLIPPER_PORT=41184
JOPLIN_WEB_CLIPPER_TOKEN=your_joplin_web_clipper_token_here

# Alternative LLM Providers (uncomment to use)
# OPENAI_API_KEY=your_openai_api_key_here
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Application Settings
DEBUG=false

# ===========================================
# Quick Setup Guide:
# 1. Get DeepSeek API key from https://platform.deepseek.com/
# 2. Get Telegram bot token from @BotFather
# 3. Get your user ID from @userinfobot
# 4. Replace the placeholder values above
# 5. Run: python main.py
# ===========================================