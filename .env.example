# ===========================================
# 智能 Joplin 图书管理员 - DeepSeek 配置
# ===========================================

# LLM 提供商选择
# 推荐使用 DeepSeek，经济实惠且响应质量高
LLM_PROVIDER=deepseek

# DeepSeek 配置
# 从以下地址获取免费 API 密钥：https://platform.deepseek.com/
# 注册后，进入 API Keys 页面并创建新密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Telegram 机器人配置
# 从 Telegram 的 @BotFather 获取机器人令牌
# 发送 /newbot 并按照说明操作
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 安全配置
# 添加你的 Telegram 用户 ID（你可以从 @userinfobot 获取）
ALLOWED_TELEGRAM_USER_IDS=your_user_id_here

# Joplin 配置
# 重要：设置 Joplin Web Clipper 授权令牌
# 1. 打开 Joplin 应用程序
# 2. 进入 工具 → 选项 → Web Clipper
# 3. 生成或设置授权令牌
# 4. 将令牌复制到这里
JOPLIN_WEB_CLIPPER_PORT=41184
JOPLIN_WEB_CLIPPER_TOKEN=your_joplin_web_clipper_token_here

# 替代 LLM 提供商（取消注释以使用）
# OPENAI_API_KEY=your_openai_api_key_here
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Google Tasks 集成（可选）
# 设置 Google Cloud Console 项目并启用 Tasks API
# 从以下地址获取凭据：https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# 食谱图像生成（可选）- Google AI Studio 免费版
# 从以下地址获取密钥：https://aistudio.google.com/apikey
# 设置后，食谱笔记顶部会有 AI 生成的食物图像
GEMINI_API_KEY=your_gemini_api_key_here

# URL 截图：从链接创建的笔记顶部会有页面截图。
# 使用 PageShot（免费，无需 API 密钥）。设置 GEMINI_API_KEY 时，食谱笔记使用 AI 图像。

# 应用程序设置
DEBUG=false
# 语言：en（英语）或 zh（中文）
LANGUAGE=en

# 本地数据路径（将运行时工件排除在项目根目录之外）
LOGS_DB_PATH=data/bot/bot_logs.db
STATE_DB_PATH=data/bot/conversation_state.db

# ===========================================
# 快速设置指南：
# 1. 从 https://platform.deepseek.com/ 获取 DeepSeek API 密钥
# 2. 从 @BotFather 获取 Telegram 机器人令牌
# 3. 从 @userinfobot 获取你的用户 ID
# 4. 替换上面的占位符值
# 5. 运行：python main.py
# ===========================================
