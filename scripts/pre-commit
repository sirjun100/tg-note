#!/bin/sh
# Pre-commit hook: run ruff and mypy before allowing commit.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e
cd "$(git rev-parse --show-toplevel)"

echo "Running ruff..."
.venv/bin/ruff check src/ config.py main.py

echo "Running mypy..."
.venv/bin/mypy src/ --ignore-missing-imports --no-strict-optional --explicit-package-bases

echo "Lint and mypy passed."
